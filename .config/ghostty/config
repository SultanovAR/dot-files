#looking
macos-titlebar-style = hidden
window-decoration = none
theme=GitHub Dark Colorblind

#keybinds
keybind = ctrl+shift+k=scroll_page_fractional:-0.5
keybind = ctrl+shift+j=scroll_page_fractional:0.5
# MacOS
clipboard-read = allow
clipboard-write = allow
copy-on-select = false
# Shell integration (zsh) for prompt marks, working-dir reporting, etc.
shell-integration = zsh
shell-integration-features = cursor,sudo,title
# Scrollback large enough for long tmux sessions and command output
scrollback-limit = 1000000
#font
font-family=GoMono Nerd Font
font-size=28

